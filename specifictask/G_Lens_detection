"code","source":"def compute_dataset_stats(df, max_samples=500):\n    sample_df = df.sample(min(max_samples, len(df)), random_state=CFG.seed)\n    means, stds = [], []\n    for path in sample_df['data_path']:\n        img = np.load(path).astype(np.float32)\n        means.append(img.mean(axis=(1, 2)))\n        stds.append(img.std(axis=(1, 2)))\n    mean = np.mean(means, axis=0).tolist()\n    std  = [max(s, 1e-6) for s in np.mean(stds, axis=0).tolist()]\n    return mean, std\n\nDATASET_MEAN, DATASET_STD = compute_dataset_stats(full_train_df)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T08:56:26.521390Z","iopub.execute_input":"2026-03-11T08:56:26.521824Z","iopub.status.idle":"2026-03-11T08:56:30.376334Z","shell.execute_reply.started":"2026-03-11T08:56:26.521799Z","shell.execute_reply":"2026-03-11T08:56:30.375752Z"}},"outputs":[],"execution_count":6},{"cell_type":"code","source":"def get_transforms(*, data):\n    norm = A.Normalize(mean=DATASET_MEAN, std=DATASET_STD)\n    if data == 'train':\n        return A.Compose([\n            A.Resize(CFG.size[0], CFG.size[1]),\n            A.OneOf([\n                A.RandomBrightnessContrast(brightness_limit=0.2, contrast_limit=0.2, p=0.5),\n                A.RandomGamma(gamma_limit=(80, 120), p=0.5),\n            ], p=0.5),\n            A.OneOf([\n                A.GaussNoise(var_limit=(10.0, 50.0), p=0.5),\n                A.GaussianBlur(blur_limit=(3, 7), p=0.5),\n            ], p=0.5),\n            A.ShiftScaleRotate(shift_limit=0.1, scale_limit=0.2, rotate_limit=30, p=0.5),\n            A.HorizontalFlip(p=0.5),\n            A.VerticalFlip(p=0.5),\n            A.CoarseDropout(max_holes=8, max_height=8, max_width=8, p=0.3),\n            norm,\n            ToTensorV2(),\n        ])\n    else:\n        return A.Compose([\n            A.Resize(CFG.size[0], CFG.size[1]),\n            norm,\n            ToTensorV2(),\n        ])","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T08:56:30.377370Z","iopub.execute_input":"2026-03-11T08:56:30.377635Z","iopub.status.idle":"2026-03-11T08:56:30.383772Z","shell.execute_reply.started":"2026-03-11T08:56:30.377604Z","shell.execute_reply":"2026-03-11T08:56:30.383049Z"}},"outputs":[],"execution_count":7},{"cell_type":"code","source":"class CustomDataset(Dataset):\n    def __init__(self, df, transform=None):\n        self.df        = df\n        self.transform = transform\n\n    def __len__(self):\n        return len(self.df)\n\n    def __getitem__(self, idx):\n        img   = np.load(self.df['data_path'].iloc[idx]).astype(np.float32)\n        img   = np.transpose(img, (1, 2, 0))\n        label = self.df['target'].iloc[idx]\n        if self.transform:\n            img = self.transform(image=img)['image']\n        return img, torch.tensor(label, dtype=torch.float32)\n\n\ndef get_sampler(df):\n    class_counts   = df['target'].value_counts().sort_index().values\n    weights        = 1.0 / class_counts\n    sample_weights = torch.tensor([weights[t] for t in df['target'].values])\n    return WeightedRandomSampler(sample_weights, len(sample_weights))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T08:56:30.384648Z","iopub.execute_input":"2026-03-11T08:56:30.384878Z","iopub.status.idle":"2026-03-11T08:56:30.402872Z","shell.execute_reply.started":"2026-03-11T08:56:30.384860Z","shell.execute_reply":"2026-03-11T08:56:30.402147Z"}},"outputs":[],"execution_count":8},{"cell_type":"code","source":"class PretrainedModel(nn.Module):\n    def __init__(self, model_name='resnet18', pretrained=True):\n        super().__init__()\n        self.model = timm.create_model(model_name, pretrained=pretrained, in_chans=3)\n        n_features = self.model.fc.in_features\n        self.model.fc = nn.Sequential(\n            nn.Dropout(0.3),\n            nn.Linear(n_features, 1)\n        )\n        nn.init.xavier_normal_(self.model.fc[1].weight)\n        nn.init.constant_(self.model.fc[1].bias, 0)\n\n    def forward(self, x):\n        return self.model(x)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T08:56:30.403805Z","iopub.execute_input":"2026-03-11T08:56:30.404149Z","iopub.status.idle":"2026-03-11T08:56:30.416245Z","shell.execute_reply.started":"2026-03-11T08:56:30.404119Z","shell.execute_reply":"2026-03-11T08:56:30.415588Z"}},"outputs":[],"execution_count":9},{"cell_type":"code","source":"class TrainUtils:\n    def __init__(self, cfg):\n        self.cfg = cfg\n\n    @property\n    def get_criterion(self):\n        return nn.BCEWithLogitsLoss(\n            pos_weight=torch.tensor([self.cfg.pos_weight]).to(self.cfg.device)\n        )\n\n    def get_score(self, y_true, y_pred):\n        score = roc_auc_score(y_true, y_pred)\n        return max(score, 1 - score)\n\n    def get_optimizer(self, model):\n        return torch.optim.AdamW(\n            model.parameters(),\n            lr=self.cfg.lr_max,\n            weight_decay=self.cfg.weight_decay\n        )\n\n    def get_scheduler(self, optimizer, steps_per_epoch):\n        return torch.optim.lr_scheduler.OneCycleLR(\n            optimizer,\n            max_lr=self.cfg.lr_max,\n            epochs=self.cfg.epochs,\n            steps_per_epoch=steps_per_epoch,\n            pct_start=0.1,\n            div_factor=25,\n            final_div_factor=1000\n        )","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T08:56:30.417333Z","iopub.execute_input":"2026-03-11T08:56:30.417680Z","iopub.status.idle":"2026-03-11T08:56:30.427847Z","shell.execute_reply.started":"2026-03-11T08:56:30.417653Z","shell.execute_reply":"2026-03-11T08:56:30.427204Z"}},"outputs":[],"execution_count":10},{"cell_type":"code","source":"def tta_predict(model, images):\n    preds = [\n        model(images),\n        model(torch.flip(images, dims=[3])),\n        model(torch.flip(images, dims=[2])),\n        model(torch.rot90(images, 1, [2, 3])),\n        model(torch.rot90(images, 2, [2, 3])),\n        model(torch.rot90(images, 3, [2, 3])),\n    ]\n    return torch.stack(preds).mean(0)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-11T08:56:30.428586Z","iopub.execute_input":"2026-03-11T08:56:30.428785Z","iopub.status.idle":"2026-03-11T08:56:30.438657Z","shell.execute_reply.started":"2026-03-11T08:56:30.428768Z","shell.execute_reply":"2026-03-11T08:56:30.438136Z"}},"outputs":[],"execution_count":11},{"cell_type":"code","source":"class Trainer:\n    def __init__(self, cfg):\n        self.cfg = cfg\n\n    def train_epoch(self, loader, model, criterion, optimizer, scheduler, epoch):\n        model.train()\n        running_loss = 0.0\n        scaler = torch.cuda.amp.GradScaler()\n        for images, labels in loader:\n            images = images.to(self.cfg.device)\n            labels = labels.to(self.cfg.device).view(-1, 1)\n            optimizer.zero_grad()\n            with torch.cuda.amp.autocast():\n                outputs = model(images)\n                loss    = criterion(outputs, labels)\n            scaler.scale(loss).backward()\n            torch.nn.utils.clip_grad_norm_(model.parameters(), self.cfg.max_grad_norm)\n            scaler.step(optimizer)\n            scaler.update()\n            if scheduler:\n                scheduler.step()\n            running_loss += loss.item()\n        print(f\"Epoch {epoch+1} Train: {len(loader)}/{len(loader)} batches done\")\n        return running_loss / len(loader)\n\n    def valid_epoch(self, loader, model, criterion, utils, epoch):\n        model.eval()\n        running_loss = 0.0\n        y_true, y_pred = [], []\n        with torch.no_grad():\n            for images, labels in loader:\n                images = images.to(self.cfg.device)\n                labels = labels.to(self.cfg.device).view(-1, 1)\n                outputs = model(images)\n                loss    = criterion(outputs, labels)\n                running_loss += loss.item()\n                y_true.extend(labels.cpu().numpy())\n                y_pred.extend(torch.sigmoid(outputs).cpu().numpy())\n        print(f\"Epoch {epoch+1} Validation: {len(loader)}/{len(loader)} batches done\")\n        y_true = np.array(y_true).reshape(-1)\n        y_pred = np.array(y_pred).reshape(-1)\n        score  = utils.get_score(y_true, y_pred)\n        return running_loss / len(loader), score\n\n    def train_loop(self, train_data, valid_data):\n        train_loader = DataLoader(\n            CustomDataset(train_data, get_transforms(data='train')),\n            batch_size=self.cfg.batch_size,\n            sampler=get_sampler(train_data),\n            num_workers=self.cfg.num_workers,\n            pin_memory=True\n        )\n        valid_loader = DataLoader(\n            CustomDataset(valid_data, get_transforms(data='test')),\n            batch_size=self.cfg.batch_size,\n            sampler=get_sampler(valid_data),\n            num_workers=self.cfg.num_workers,\n            pin_memory=True\n        )\n\n        model     = PretrainedModel(self.cfg.model_name, pretrained=True).to(self.cfg.device)\n        utils     = TrainUtils(self.cfg)\n        optimizer = utils.get_optimizer(model)\n        scheduler = utils.get_scheduler(optimizer, len(train_loader))\n        criterion = utils.get_criterion\n\n        best_score, best_model, patience_counter = -1, None, 0\n\n        for epoch in range(self.cfg.epochs):\n            train_loss = self.train_epoch(train_loader, model, criterion, optimizer, scheduler, epoch)\n            val_loss, score = self.valid_epoch(valid_loader, model, criterion, utils, epoch)\n\n            print(f\"Epoch {epoch+1:02d}/{self.cfg.epochs} | \"\n                  f\"Train Loss: {train_loss:.4f} | \"\n                  f\"Val Loss: {val_loss:.4f} | \"\n                  f\"ROC-AUC: {score:.4f}\")\n\n            if score > best_score:\n                best_score, best_model, patience_counter = score, copy.deepcopy(model), 0\n                torch.save(model.state_dict(), f\"./{self.cfg.model_name}_best.